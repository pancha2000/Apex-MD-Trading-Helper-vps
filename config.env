# ─── WEB DASHBOARD ────────────────────────────────────────────
# Dashboard runs on a SEPARATE port from the main WhatsApp keep-alive server.
# Default: http://YOUR_VPS_IP:3000
DASHBOARD_PORT=3000
DASHBOARD_PASSWORD="apex2024secure"
# Random secret for signing session cookies — CHANGE THIS to something unique!
DASHBOARD_SECRET="change-me-apex-md-secret-2024-xyz"

# ─── MODULE TOGGLES ───────────────────────────────────────────
# Set to false to disable a module without deleting its code.
# Changes here take effect after bot restart.
# The dashboard Settings page can also toggle these at runtime.

# Local Python LSTM AI prediction server (http://localhost:5000/predict)
ENABLE_AI_MODEL=true

# Bybit cross-exchange orderbook/volume validation
ENABLE_BYBIT=true

# ADX/ATR-based dynamic weight multipliers for the scoring system
ENABLE_DYNAMIC_WEIGHTS=true

# SMC-specific score factors (ChoCH, Sweep, OB, Wyckoff, BOS, etc.)
# Disable for speed-sensitive environments — base indicators still run
ENABLE_SMC=true

# ─── TRADING PARAMETERS ───────────────────────────────────────
# Risk percentage per trade (2 = 2% of margin)
DEFAULT_RISK_PCT=2

# Maximum number of simultaneously open trades the bot will track
MAX_OPEN_TRADES=5

# Minimum 14-Factor score required for a signal to be valid (0–100 scale)
MIN_SCORE_THRESHOLD=20

# Default leverage for position sizing calculations
DEFAULT_LEVERAGE=10

# ─── AUTO-UPDATER ─────────────────────────────────────────────
# When enabled, the dashboard can trigger: git pull + npm install + pm2 restart
ENABLE_AUTO_UPDATE=false

# pm2 process name (set in your ecosystem.config.js or how you start the bot)
PM2_APP_NAME="ApexBot"

# Optional: GitHub webhook secret for automatic push-triggered updates
# Leave empty to disable webhook — use the dashboard button instead
GITHUB_WEBHOOK_SECRET=""

# ─── AI MODEL (Python FastAPI server) ─────────────────────────
AI_MODEL_URL="http://localhost:5000"
AI_MODEL_TIMEOUT=6000

# Confidence threshold to award score points (60–100)
AI_CONFIDENCE_THRESHOLD=60

# Confidence threshold to BLOCK a trade when AI strongly opposes (70–100)
AI_BLOCK_THRESHOLD=80

# ─── BYBIT SETTINGS ───────────────────────────────────────────
BYBIT_TIMEOUT=5000
BYBIT_OB_DEPTH=20

# ─── SCANNER SETTINGS ─────────────────────────────────────────
# Number of top coins to watch in the WebSocket stream
WS_WATCH_COUNT=30

# Auto-scan signal cooldown in hours (prevents same coin re-signalling)
SIGNAL_COOLDOWN_HOURS=4
